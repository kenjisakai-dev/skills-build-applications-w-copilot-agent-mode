# Variáveis de ambiente do frontend (Vite)
# Copie este arquivo como .env.local e preencha os valores

# Nome do Codespace do GitHub. Necessário para construir a URL da API.
# Exemplo: VITE_CODESPACE_NAME=my-codespace-name
# URL resultante: https://my-codespace-name-8000.app.github.dev
# Se não definido, a app usa http://localhost:8000 como fallback.
VITE_CODESPACE_NAME=
